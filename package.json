{
  "name": "ipfs-tracker",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prestart": "npm run build",
    "start": "node ./dist/bin/www.js",
    "dev": "tsx watch ./bin/www.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@multiformats/multiaddr": "12.3.1",
    "cors": "2.8.5",
    "debug": "4.4.3",
    "dotenv": "16.4.5",
    "express": "5.2.1",
    "ipaddr.js": "2.4.0",
    "morgan": "1.11.0",
    "multiformats": "13.2.2",
    "prom-client": "15.1.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/debug": "4.1.13",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "@types/node": "22.20.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
